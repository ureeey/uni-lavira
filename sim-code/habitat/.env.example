# Copy this file to .env.local (which is gitignored) and fill in your API keys.
# Then source both files before running:
#   source .env.local && source env.sh
#
# LAVIRA uses two model agents:
#   - LA (Language Agent) — high-level reasoning / TODO planning / answer synthesis.
#                            ⚠️  LA receives panorama images → MUST be a multimodal model
#                            (e.g. qwen3.6-plus, qwen-vl-plus, gemini-3.5-flash).
#                            Text-only models like deepseek-v4-pro will NOT work.
#   - VA (Vision Agent)  — per-step vision-language understanding from egocentric RGB.
#                            Recommended: qwen3.5-27b via Aliyun DashScope
#                            or self-hosted vLLM.
#
# Both endpoints must speak the OpenAI Chat-Completions API (v1/chat/completions).
#
# System / runtime config (HF offline, GPU PRIME offload, etc.) lives in env.sh
# — that file is safe to commit and contains sensible defaults.

# --- Language Agent (LA) ---
LA_API_KEY=
LA_BASE_URL=https://yunwu.ai/v1
LA_MODEL_NAME=gemini-3.5-flash

# --- Vision Agent (VA) ---
VA_API_KEY=
VA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VA_MODEL_NAME=qwen3.5-27b
