# Copy this file to .env (which is gitignored) and fill in the values.
#
# LAVIRA uses two model agents:
#   - LA (Language Agent) — high-level reasoning / TODO planning / answer synthesis.
#                            Recommended: gemini-3.5-flash (validated default) or the higher-tier
#                            gemini-3.1-pro via yunwu.ai; any OpenAI-compatible chat endpoint works.
#   - VA (Vision Agent)  — per-step vision-language understanding from egocentric RGB.
#                            Recommended: qwen3.5-27b via Aliyun DashScope
#                            or self-hosted vLLM.
#
# Both endpoints must speak the OpenAI Chat-Completions API (v1/chat/completions).

# --- Language Agent (LA) ---
LA_API_KEY=
LA_BASE_URL=https://yunwu.ai/v1
LA_MODEL_NAME=gemini-3.5-flash

# --- Vision Agent (VA) ---
VA_API_KEY=
VA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VA_MODEL_NAME=qwen3.5-27b
